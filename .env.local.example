# Renomeie este arquivo para .env.local e preencha com suas credenciais.
# Voce encontra esses valores em Supabase > Settings > API.

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=coloque-sua-anon-key-aqui

# Koliseu Cloud - Gateway PIX (server-side apenas, nunca exponha ao browser)
KOLISEU_API_KEY=ksl_...
KOLISEU_BASE_URL=https://www.koliseu.cloud/api/v1
